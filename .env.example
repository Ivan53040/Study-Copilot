# Optional overrides. Copy to .env (which is git-ignored).

# Path to the YAML config (defaults to ./config.yaml)
STUDY_COPILOT_CONFIG=config.yaml

# Cloud model keys. Only read when models.default_provider is set to the
# matching cloud provider in config.yaml ("anthropic" -> ANTHROPIC_API_KEY,
# "openai" -> OPENAI_API_KEY). Left local-first by default.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
